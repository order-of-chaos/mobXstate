{
  "name": "mobxstate",
  "version": "0.0.1",
  "description": "XState-shaped finite state machines for MobX stores without a separate machine context.",
  "type": "module",
  "license": "MIT",
  "author": "egortrubnikov-panov <egort@brainway.co.il>",
  "keywords": [
    "mobx",
    "xstate",
    "statecharts",
    "state-machine",
    "finite-state-machine",
    "mobx-state-machine",
    "stately"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/index.*",
    "dist/BaseMachineState",
    "docs",
    "examples/live",
    "examples/standalone"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "dev": "vite",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false && tsc -p tsconfig.test.json && tsc -p tsconfig.type-tests.json && tsc -p tsconfig.examples.json",
    "build": "npm run clean && tsc && vite build",
    "lint": "eslint src examples --ext ts --report-unused-disable-directives --max-warnings 0",
    "pack:dry-run": "npm pack --dry-run",
    "test": "vitest"
  },
  "dependencies": {
    "ts-pattern": "^5.0.1"
  },
  "peerDependencies": {
    "mobx": "^6.9.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.61.0",
    "@typescript-eslint/parser": "^5.61.0",
    "eslint": "^8.44.0",
    "typescript": "^5.0.2",
    "vite": "^4.4.0",
    "vitest": "^0.32.2"
  }
}
