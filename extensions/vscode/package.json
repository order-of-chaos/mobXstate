{
  "name": "mobxstate-devtools-vscode",
  "displayName": "MobXstate Devtools",
  "description": "VS Code shell for MobXstate viewer, visual editor, diagnostics and typegen.",
  "version": "0.0.1",
  "private": true,
  "publisher": "orderofchaos",
  "scripts": {
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('media',{recursive:true,force:true})\"",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.webview.json && node scripts/build-extension.mjs && node scripts/build-webview.mjs",
    "build:extension": "node scripts/build-extension.mjs",
    "build:webview": "node scripts/build-webview.mjs",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.webview.json"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "files": [
    "dist",
    "media",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onCommand:mobxstate.openViewer",
    "onCommand:mobxstate.openVisualEditor",
    "onCommand:mobxstate.generateTypegen",
    "onCommand:mobxstate.checkCurrentFile",
    "onCommand:mobxstate.exportMachineConfig"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mobxstate.openViewer",
        "title": "MobXstate: Open Viewer"
      },
      {
        "command": "mobxstate.openVisualEditor",
        "title": "MobXstate: Open Visual Editor"
      },
      {
        "command": "mobxstate.generateTypegen",
        "title": "MobXstate: Generate Typegen"
      },
      {
        "command": "mobxstate.checkCurrentFile",
        "title": "MobXstate: Check Current File"
      },
      {
        "command": "mobxstate.exportMachineConfig",
        "title": "MobXstate: Export Machine Config"
      }
    ]
  },
  "devDependencies": {
    "@orderofchaos/mobxstate": "file:../..",
    "@xyflow/react": "^12.11.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
